# ──────────────────────────────────────────────────────
# Safety NOTE - 환경변수 설정 파일 예시
# 이 파일을 복사해서 .env 로 저장한 후 값을 수정하세요.
#   cp .env.example .env
# ──────────────────────────────────────────────────────

# ── 서버 ──────────────────────────────────────────────
# 서버 포트
# ⚠️ NAS 배포 시 반드시 3443으로 설정할 것!
# (공유기 포트포워딩: 외부 3443 → NAS 3443, 리버스프록시 없음)
PORT=3443

# ── 데이터베이스 ──────────────────────────────────────
# SQLite DB 파일 경로 (지정하지 않으면 wrangler local D1 또는 safety.db 자동 사용)
# 로컬 파일:  DB_PATH=./safety.db
# NAS 예시:   DB_PATH=/mnt/nas/safetynote/safety.db
DB_PATH=

# ── 파일 업로드 ───────────────────────────────────────
# 사진/동영상 저장 루트 폴더
# 기본값(미설정): 프로젝트 내 public/uploads/
# NAS 마운트 예시:
#   UPLOAD_PATH=/mnt/nas/safetynote/uploads
#   UPLOAD_PATH=/volume1/safetynote/uploads     (Synology NAS)
#   UPLOAD_PATH=/share/safetynote/uploads       (QNAP NAS)
#   UPLOAD_PATH=//NAS_IP/share/uploads          (Windows UNC)
UPLOAD_PATH=

# 연도/월 하위폴더 자동 생성 여부 (기본값: true)
# true  → UPLOAD_PATH/2025/05/파일명.jpg  형태로 저장
# false → UPLOAD_PATH/파일명.jpg          형태로 저장 (단일 폴더)
UPLOAD_SUBDIR=true
