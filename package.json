{
  "name": "webapp",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "dev:sandbox": "wrangler pages dev dist --d1=safety-management-production --local --ip 0.0.0.0 --port 3000",
    "deploy": "npm run build && wrangler pages deploy dist",
    "db:migrate:local": "wrangler d1 migrations apply safety-management-production --local",
    "db:seed": "wrangler d1 execute safety-management-production --local --file=./migrations/0002_seed_data.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "better-sqlite3": "^9.6.0",
    "hono": "^4.12.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260417.1",
    "@hono/vite-cloudflare-pages": "^0.4.3",
    "@types/better-sqlite3": "^7.6.13",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
