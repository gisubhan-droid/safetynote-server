# ══════════════════════════════════════════════════════════════
# SafetyNOTE 환경 설정 예시
# 사용법: cp .env.example .env  →  값 수정 후 서버 재시작
# ⚠️ .env 파일은 절대 GitHub에 올리지 마세요!
# ══════════════════════════════════════════════════════════════

# ── 서버 포트 ──────────────────────────────────────────────────
# ⚠️ NAS 배포 시 반드시 3443 유지
#    (공유기 포트포워딩: 외부 3443 → NAS 3443 고정값)
PORT=3443

# ── 데이터베이스 경로 ──────────────────────────────────────────
# 미설정 시: 프로젝트 폴더 내 safety.db 자동 사용
# NAS 예시:  DB_PATH=/volume1/safetynote/safety.db
DB_PATH=

# ── 파일 업로드 경로 ───────────────────────────────────────────
# 미설정 시: 프로젝트 폴더 내 public/uploads/ 자동 사용
# NAS 예시:  UPLOAD_PATH=/volume1/safetynote/public/uploads
UPLOAD_PATH=

# 연도/월 하위폴더 자동 생성 (기본: true)
#   true  → YYYY/MM/파일명.jpg 형태로 저장
#   false → 파일명.jpg 형태로 저장 (단일 폴더)
UPLOAD_SUBDIR=true

# ── 보안 키 ────────────────────────────────────────────────────
# ⚠️ NAS마다 반드시 고유한 값으로 설정하세요!
#    생성 방법: cat /dev/urandom | tr -dc 'a-zA-Z0-9' | fold -w 32 | head -n 1
JWT_SECRET=

# ── APK 자동 배포 Webhook 시크릿 ──────────────────────────────
# GitHub Actions DEPLOY_WEBHOOK_SECRET 값과 동일하게 설정
DEPLOY_WEBHOOK_SECRET=safetynote-nas-2026

# ── 앱 버전 ────────────────────────────────────────────────────
APP_VERSION=1.4

# ── Firebase FCM 푸시 알림 (선택사항) ─────────────────────────
# 사용 안 하면 아래 항목 모두 비워두세요.
# Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 → 키 생성
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
